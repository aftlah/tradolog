---
import RootLayout from '@shared/layouts/RootLayout.astro';
import { ResetPasswordPage } from '@features/auth';

const token = Astro.url.searchParams.get('token');
const hasInvalidToken = Astro.url.searchParams.get('error') === 'INVALID_TOKEN';
---

<RootLayout title="Reset Password — Tradolog">
	<ResetPasswordPage client:idle token={token} hasInvalidToken={hasInvalidToken} />
</RootLayout>
