---
import RootLayout from '@shared/layouts/RootLayout.astro';
import { DashboardShell, dashboardService } from '@features/dashboard';

const session = Astro.locals.session;

if (!session) {
	return Astro.redirect('/login');
}

const requestedAccountId = Astro.url.searchParams.get('accountId');
const dashboardData = await dashboardService.getDashboardData(session.user.id, requestedAccountId);

const userName = session.user.name ?? 'Trader';
const userEmail = session.user.email ?? '';
---

<RootLayout title="Dashboard — Tradolog">
	<DashboardShell client:load initialData={dashboardData} userName={userName} userEmail={userEmail} />
</RootLayout>
