---
import AppLayout from '@features/shell/layouts/AppLayout.astro';
import { DashboardShell } from '@features/dashboard/components/DashboardShell';
import { dashboardService } from '@features/dashboard/services/dashboard.service';

const session = Astro.locals.session;

if (!session) {
	return Astro.redirect('/login');
}

const requestedAccountId = Astro.url.searchParams.get('accountId');
const dashboardData = await dashboardService.getDashboardData(session.user.id, requestedAccountId);

const userName = session.user.name ?? 'Trader';
const userEmail = session.user.email ?? '';
---

<AppLayout
	title="Dashboard — Tradolog"
	pageTitle="Dashboard"
	userName={userName}
	userEmail={userEmail}
	accounts={dashboardData.accounts}
	activeAccountId={dashboardData.activeAccountId}
>
	<DashboardShell client:idle initialData={dashboardData} />
</AppLayout>
