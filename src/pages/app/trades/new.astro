---
import AppLayout from '@features/shell/layouts/AppLayout.astro';
import { TradeCreateShell } from '@features/trade/components/TradeCreateShell';
import { tradeJournalService } from '@features/trade/services/trade-journal.service';

const session = Astro.locals.session;

if (!session) {
	return Astro.redirect('/login');
}

const userId = session.user.id;
const options = await tradeJournalService.getFormOptions(userId);

const requestedAccountId = Astro.url.searchParams.get('accountId');
const defaultAccount =
	(requestedAccountId ? options.accounts.find((account) => account.id === requestedAccountId) : undefined) ??
	options.accounts.find((account) => account.isDefault) ??
	options.accounts[0];

const userName = session.user.name ?? 'Trader';
const userEmail = session.user.email ?? '';
const nowIso = new Date().toISOString();
---

<AppLayout
	title="New Trade — Tradolog"
	pageTitle="New Trade"
	userName={userName}
	userEmail={userEmail}
	accounts={options.accounts}
	activeAccountId={defaultAccount?.id ?? null}
	showQuickAdd={false}
	accountChangePath="/app/trades"
>
	<TradeCreateShell client:only="react" options={options} defaultAccountId={defaultAccount?.id ?? null} nowIso={nowIso}>
		<p class="text-sm text-muted">Loading trade form…</p>
	</TradeCreateShell>
</AppLayout>
