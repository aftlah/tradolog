---
import AppLayout from '@features/shell/layouts/AppLayout.astro';
import { TradeDetailShell } from '@features/trade/components/TradeDetailShell';
import { tradeJournalService } from '@features/trade/services/trade-journal.service';
import { NotFoundError } from '@shared/lib/errors';
import { tradingAccountService } from '@shared/services';
import { toAccountOption } from '@shared/utils/account-option';

const session = Astro.locals.session;

if (!session) {
	return Astro.redirect('/login');
}

const { id } = Astro.params;
if (!id) {
	return Astro.redirect('/app/trades');
}

const userId = session.user.id;

let trade;
let accounts;
try {
	[trade, accounts] = await Promise.all([
		tradeJournalService.getDetail(id, userId),
		tradingAccountService.list(userId),
	]);
} catch (error) {
	if (error instanceof NotFoundError) {
		return Astro.redirect('/app/trades');
	}
	throw error;
}

const userName = session.user.name ?? 'Trader';
const userEmail = session.user.email ?? '';
---

<AppLayout
	title={`${trade.symbol} — Tradolog`}
	pageTitle="Trade Detail"
	userName={userName}
	userEmail={userEmail}
	accounts={accounts.map(toAccountOption)}
	activeAccountId={trade.accountId}
	showQuickAdd={false}
	accountChangePath="/app/trades"
>
	<TradeDetailShell client:idle trade={trade} />
</AppLayout>
