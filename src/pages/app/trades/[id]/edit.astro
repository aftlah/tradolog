---
import AppLayout from '@features/shell/layouts/AppLayout.astro';
import { TradeEditShell } from '@features/trade/components/TradeEditShell';
import { tradeJournalService } from '@features/trade/services/trade-journal.service';
import { NotFoundError } from '@shared/lib/errors';

const session = Astro.locals.session;

if (!session) {
	return Astro.redirect('/login');
}

const { id } = Astro.params;
if (!id) {
	return Astro.redirect('/app/trades');
}

const userId = session.user.id;

let trade;
let options;
try {
	[trade, options] = await Promise.all([
		tradeJournalService.getDetail(id, userId),
		tradeJournalService.getFormOptions(userId),
	]);
} catch (error) {
	if (error instanceof NotFoundError) {
		return Astro.redirect('/app/trades');
	}
	throw error;
}
const userName = session.user.name ?? 'Trader';
const userEmail = session.user.email ?? '';
---

<AppLayout
	title={`Edit ${trade.symbol} — Tradolog`}
	pageTitle="Edit Trade"
	userName={userName}
	userEmail={userEmail}
	accounts={options.accounts}
	activeAccountId={trade.accountId}
	showQuickAdd={false}
	accountChangePath="/app/trades"
>
	<TradeEditShell client:only="react" trade={trade} options={options}>
		<p class="text-sm text-muted">Loading trade form…</p>
	</TradeEditShell>
</AppLayout>
