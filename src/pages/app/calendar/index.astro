---
import AppLayout from '@features/shell/layouts/AppLayout.astro';
import { CalendarShell } from '@features/calendar/components/CalendarShell';
import { calendarService } from '@features/calendar/services/calendar.service';
import { parseCalendarQuery } from '@features/calendar/utils/query';

const session = Astro.locals.session;

if (!session) {
	return Astro.redirect('/login');
}

const query = parseCalendarQuery(Astro.url.searchParams);
const calendarData = await calendarService.getCalendarData(session.user.id, query.year, query.month, query.accountId);

const userName = session.user.name ?? 'Trader';
const userEmail = session.user.email ?? '';
---

<AppLayout
	title="Calendar — Tradolog"
	pageTitle="Calendar"
	userName={userName}
	userEmail={userEmail}
	accounts={calendarData.accounts}
	activeAccountId={calendarData.activeAccountId}
>
	<CalendarShell client:load initialData={calendarData} />
</AppLayout>
