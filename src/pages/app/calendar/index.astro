---
import AppLayout from '@features/shell/layouts/AppLayout.astro';
import { CalendarShell } from '@features/calendar/components/CalendarShell';
import { calendarService } from '@features/calendar/services/calendar.service';
import { parseCalendarQuery } from '@features/calendar/utils/query';
import { ACTIVE_ACCOUNT_COOKIE } from '@shared/constants/account.constants';
import { readActiveAccountCookieValue } from '@shared/utils/active-account-cookie';

const session = Astro.locals.session;

if (!session) {
	return Astro.redirect('/login');
}

const query = parseCalendarQuery(Astro.url.searchParams);
if (!query.accountId) {
	query.accountId =
		readActiveAccountCookieValue(Astro.cookies.get(ACTIVE_ACCOUNT_COOKIE)?.value) ?? undefined;
}

const calendarData = await calendarService.getCalendarData(
	session.user.id,
	query.year,
	query.month,
	query.accountId,
);

if (calendarData.activeAccountId) {
	Astro.cookies.set(ACTIVE_ACCOUNT_COOKIE, calendarData.activeAccountId, {
		path: '/',
		maxAge: 60 * 60 * 24 * 365,
		sameSite: 'lax',
		httpOnly: false,
	});
}

const userName = session.user.name ?? 'Trader';
const userEmail = session.user.email ?? '';
---

<AppLayout
	title="Calendar — Tradolog"
	pageTitle="Calendar"
	userName={userName}
	userEmail={userEmail}
	accounts={calendarData.accounts}
	activeAccountId={calendarData.activeAccountId}
>
	<CalendarShell client:idle initialData={calendarData} />
</AppLayout>
