---
import AppLayout from '@features/shell/layouts/AppLayout.astro';
import { NotesShell } from '@features/notes/components/NotesShell';
import { notesService } from '@features/notes/services/notes.service';
import { tradingAccountService } from '@shared/services';
import { toAccountOption } from '@shared/utils/account-option';
import { ACTIVE_ACCOUNT_COOKIE } from '@shared/constants/account.constants';
import { readActiveAccountCookieValue } from '@shared/utils/active-account-cookie';

const session = Astro.locals.session;

if (!session) {
	return Astro.redirect('/login');
}

const userId = session.user.id;
const [rawAccounts, initialNotes] = await Promise.all([
	tradingAccountService.list(userId),
	notesService.list(userId),
]);
const accounts = rawAccounts.map(toAccountOption);

const requestedAccountId =
	Astro.url.searchParams.get('accountId') ??
	readActiveAccountCookieValue(Astro.cookies.get(ACTIVE_ACCOUNT_COOKIE)?.value);
const activeAccountId =
	(requestedAccountId && accounts.some((account) => account.id === requestedAccountId)
		? requestedAccountId
		: null) ??
	accounts.find((account) => account.isDefault)?.id ??
	accounts[0]?.id ??
	null;

if (activeAccountId) {
	Astro.cookies.set(ACTIVE_ACCOUNT_COOKIE, activeAccountId, {
		path: '/',
		maxAge: 60 * 60 * 24 * 365,
		sameSite: 'lax',
		httpOnly: false,
	});
}

const userName = session.user.name ?? 'Trader';
const userEmail = session.user.email ?? '';
---

<AppLayout
	title="Notes — Tradolog"
	pageTitle="Notes"
	userName={userName}
	userEmail={userEmail}
	accounts={accounts}
	activeAccountId={activeAccountId}
>
	<NotesShell client:idle initialNotes={initialNotes} />
</AppLayout>
