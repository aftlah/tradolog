---
import AppLayout from '@features/shell/layouts/AppLayout.astro';
import { NotesShell } from '@features/notes/components/NotesShell';
import { notesService } from '@features/notes/services/notes.service';
import { tradingAccountService } from '@shared/services';
import { toAccountOption } from '@shared/utils/account-option';

const session = Astro.locals.session;

if (!session) {
	return Astro.redirect('/login');
}

const userId = session.user.id;
const rawAccounts = await tradingAccountService.list(userId);
const accounts = rawAccounts.map(toAccountOption);

const requestedAccountId = Astro.url.searchParams.get('accountId');
const activeAccountId =
	(requestedAccountId && accounts.some((account) => account.id === requestedAccountId) ? requestedAccountId : null) ??
	accounts.find((account) => account.isDefault)?.id ??
	accounts[0]?.id ??
	null;

const initialNotes = await notesService.list(userId);

const userName = session.user.name ?? 'Trader';
const userEmail = session.user.email ?? '';
---

<AppLayout
	title="Notes — Tradolog"
	pageTitle="Notes"
	userName={userName}
	userEmail={userEmail}
	accounts={accounts}
	activeAccountId={activeAccountId}
>
	<NotesShell client:load initialNotes={initialNotes} />
</AppLayout>
