---
import '@shared/styles/globals.css';
import { ClientRouter } from 'astro:transitions';
import { Toaster } from '@shared/components';

interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'Tradolog',
	description = 'Modern SaaS trading journal for recording, reviewing, and improving trading performance.',
} = Astro.props;
---

<!doctype html>
<html lang="en" class="dark" transition:animate="none">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{title}</title>
		{/* Soft MPA navigations without transition animations — faster perceived page changes. */}
		<ClientRouter fallback="swap" />
		{/* Apply collapsed sidebar before first paint so navigation does not flash expanded. */}
		<script is:inline>
			try {
				if (localStorage.getItem('tradolog.sidebar.collapsed') === '1') {
					document.documentElement.dataset.sidebarCollapsed = '1';
				}
			} catch (e) {}
		</script>
		<style is:global>
			#tradolog-nav-progress {
				position: fixed;
				top: 0;
				left: 0;
				z-index: 9999;
				height: 2px;
				width: 0;
				pointer-events: none;
				background: linear-gradient(90deg, #818cf8, #a5b4fc);
				opacity: 0;
				transition:
					width 280ms ease-out,
					opacity 160ms ease;
			}
			#tradolog-nav-progress[data-active='1'] {
				opacity: 1;
				width: 78%;
			}
			#tradolog-nav-progress[data-done='1'] {
				opacity: 0;
				width: 100%;
				transition:
					width 120ms ease-out,
					opacity 220ms ease 80ms;
			}
		</style>
	</head>
	<body>
		<div id="tradolog-nav-progress" transition:persist="tradolog-nav-progress" aria-hidden="true"></div>
		<slot />
		<div transition:persist="tradolog-toaster">
			{/* Sonner has no meaningful SSR output — skip hydrate to avoid ClientRouter aborts. */}
			<Toaster client:only="react" />
		</div>
		<script is:inline>
			(function () {
				var bar = document.getElementById('tradolog-nav-progress');
				if (!bar) return;
				document.addEventListener('astro:before-preparation', function () {
					bar.removeAttribute('data-done');
					bar.setAttribute('data-active', '1');
				});
				document.addEventListener('astro:page-load', function () {
					bar.setAttribute('data-done', '1');
					bar.removeAttribute('data-active');
					window.setTimeout(function () {
						bar.removeAttribute('data-done');
						bar.style.width = '0';
					}, 280);
				});
			})();
		</script>
	</body>
</html>
