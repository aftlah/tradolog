# Database (required for auth + drizzle)
# Match host/port/user from pgAdmin → server Properties → Connection
# Example: PostgreSQL 13 on this machine uses port 5433
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5433/tradolog

# Better Auth (required — secret must be at least 32 characters)
BETTER_AUTH_SECRET=tradolog-local-dev-secret-change-me-32
BETTER_AUTH_URL=http://localhost:4321

# Google OAuth (optional — enables Continue with Google when both are set)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Cloudflare R2 (trade screenshots — later feature)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=tradolog
R2_PUBLIC_URL=https://your-bucket.example.com

# Gemini (optional — Fill trade form from setup image; free tier at AI Studio)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
